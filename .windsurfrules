3. **pygame Specific Patterns:**
   ```python
   import pygame
   from pygame import Surface, Rect, Color
   
   class GameRenderer:
       def __init__(self, screen: Surface):
           self.screen = screen
           self.clock = pygame.time.Clock()
       
       def render_frame(self, game_state: GameState) -> None:
           """Render single frame with consistent timing."""
           self.screen.fill(Colors.BACKGROUND)
           self._render_board(game_state.board)
           self._render_ui(game_state)
           pygame.display.flip()
           self.clock.tick(settings.fps)
   
   class InputHandler:
       def handle_events(self) -> List[GameEvent]:
           """Process pygame events into game events."""
           events = []
           for event in pygame.event.get():
               if event.type == pygame.QUIT:
                   events.append(GameEvent.QUIT)
               elif event.type == pygame.MOUSEBUTTONDOWN:
                   events.append(GameEvent.MOUSE_CLICK(event.pos))
           return events
   ```

### II. Architecture Patterns

1. **Game Loop Structure:**
   ```python
   class GameEngine:
       def __init__(self):
           self.state = GameState.MENU
           self.renderer = GameRenderer()
           self.input_handler = InputHandler()
           self.game_logic = GameLogic()
       
       def run(self) -> None:
           """Main game loop with fixed timestep."""
           running = True
           while running:
               # Handle input
               events = self.input_handler.handle_events()
               
               # Update game state
               self.state = self.game_logic.update(self.state, events)
               
               # Render frame
               self.renderer.render_frame(self.state)
               
               # Check for quit
               running = self.state != GameState.QUIT
   ```

